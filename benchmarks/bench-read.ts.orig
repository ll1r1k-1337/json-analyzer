import { fileURLToPath } from "node:url";
import path from "node:path";
import { stat } from "node:fs/promises";
import { BinaryTokenReader } from "../src/binary/reader.js";

const dirname = path.dirname(fileURLToPath(import.meta.url));
const outputDir = path.join(dirname, "output");

const recordCount = Number(process.env.RECORDS ?? 5000);
const binPath = path.join(outputDir, `generated-${recordCount}.bin`);
const metaPath = path.join(outputDir, `generated-${recordCount}.meta`);

const runBench = async () => {
  const start = process.hrtime.bigint();
  const reader = await BinaryTokenReader.fromFiles(metaPath, binPath);
  const trailer = reader.getTrailer();
  let offset = 0n;
  let count = 0;

  while (offset < trailer.tokenStreamLength) {
    const { token, byteLength } = await reader.readTokenAt(offset);
    count++;
    offset += BigInt(byteLength);
  }

  await reader.close();
  const end = process.hrtime.bigint();
  const seconds = Number(end - start) / 1e9;

  console.log(`Read ${count} tokens in ${seconds.toFixed(2)} s`);
  console.log(`Throughput: ${(count / seconds).toFixed(0)} tokens/s`);
};

runBench().catch(console.error);
